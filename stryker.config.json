{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "mutate": [
    "src/lib/actions/**/*.ts",
    "src/lib/validations/**/*.ts",
    "src/lib/cascade/**/*.ts",
    "src/lib/inngest/**/*.ts",
    "src/lib/certificates/**/*.ts",
    "src/lib/db/**/*.ts",
    "src/lib/auth/**/*.ts",
    "src/lib/notifications/**/*.ts",
    "src/lib/exports/**/*.ts",
    "src/lib/attendance/**/*.ts",
    "src/lib/import/**/*.ts",
    "src/lib/flags.ts",
    "src/lib/sentry.ts",
    "src/lib/utils.ts",
    "src/middleware.ts",
    "src/instrumentation.ts",
    "src/instrumentation-client.ts",
    "src/app/api/**/*.ts",
    "!src/**/*.test.ts",
    "!src/**/*.gap.test.ts",
    "!src/**/*.mutation-kill.test.ts",
    "!src/**/*.mutation-kill-2.test.ts",
    "!src/**/*.anneal.test.ts",
    "!src/**/*.census.test.ts",
    "!src/**/__tests__/**",
    "!src/**/*.spec.ts",
    "!src/app/api/test/**"
  ],
  "reporters": ["html", "json", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "reports/mutation/mutation.html"
  },
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  },
  "timeoutMS": 30000
}
