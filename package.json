{
  "name": "gem-india",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:property": "vitest run --reporter=verbose src/**/*.property.test.ts",
    "test:mutate": "npx stryker run",
    "test:e2e": "npx playwright test --config=playwright.config.ts",
    "test:e2e:smoke": "npx playwright test --config=playwright.config.ts --grep @smoke",
    "test:a11y": "npx playwright test --config=playwright.config.ts --grep @a11y",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
