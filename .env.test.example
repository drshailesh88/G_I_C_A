# E2E Test Configuration
# Copy to .env.test.local and fill in your test user credentials

# Clerk test user — create in Clerk Dashboard > Users
# Must have password authentication enabled
E2E_CLERK_USER_USERNAME=test@example.com
E2E_CLERK_USER_PASSWORD=your_test_password

# Test event ID — an event that exists in your dev database
E2E_TEST_EVENT_ID=your-test-event-uuid
