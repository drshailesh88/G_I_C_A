# E2E Test Configuration
# Copy to .env.test.local and fill in your test user credentials

# Clerk test user — create in Clerk Dashboard > Users
# Must have password authentication enabled
E2E_CLERK_USER_USERNAME=test@example.com
E2E_CLERK_USER_PASSWORD=your_test_password

# Test event ID — an event that exists in your dev database
E2E_TEST_EVENT_ID=your-test-event-uuid

# Clerk test instance secret key (sk_test_...)
CLERK_SECRET_KEY=
# Clerk test publishable key (pk_test_...)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# (optional) Admin/elevated-role test user
E2E_CLERK_ADMIN_USERNAME=
# (optional) 
E2E_CLERK_ADMIN_PASSWORD=
# (optional) Required for bot detection bypass in automation
CLERK_TESTING_TOKEN=
# Postgres URL for the test database
DATABASE_URL_TEST=
# (optional) truncate | migrate-fresh | snapshot (default: truncate)
TEST_DATABASE_SEED_STRATEGY=
# (optional) Direct (non-pooled) URL for migrations
DIRECT_URL_TEST=
# (optional) Only needed for real-send tests; MSW handles mocked sends
RESEND_API_KEY_TEST=
# (optional) Only needed if you verify events reach Sentry; usually skipped
SENTRY_DSN_TEST=
# (optional) Required for source-map uploads during release builds
SENTRY_AUTH_TOKEN=
UPSTASH_REDIS_REST_URL_TEST=
UPSTASH_REDIS_REST_TOKEN_TEST=
# (optional) 
UPSTASH_KAFKA_REST_URL=
# (optional) 
UPSTASH_KAFKA_REST_USERNAME=
# (optional) 
UPSTASH_KAFKA_REST_PASSWORD=
