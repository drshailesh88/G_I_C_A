# GEM India Conference App — Environment Variables
# Copy this to .env.local and fill in real values
# NEVER commit .env.local to git

# ============ DATABASE ============
DATABASE_URL=

# ============ AUTH (Clerk) ============
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Optional: Clerk webhook for sync
CLERK_WEBHOOK_SECRET=

# ============ FILE STORAGE (Cloudflare R2) ============
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=gem-india-files
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://files.gemindia.com

# ============ BACKGROUND JOBS (Inngest) ============
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ============ CACHE / LOCKS / FLAGS (Upstash Redis) ============
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============ EMAIL (Resend) ============
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@gemindia.org
RESEND_WEBHOOK_SECRET=

# ============ WHATSAPP (Evolution API) ============
EVOLUTION_API_BASE_URL=http://<your-droplet-ip>:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=gem-india
EVOLUTION_WEBHOOK_SECRET=

# ============ ERROR MONITORING (Sentry) ============
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ============ APP CONFIG ============
NEXT_PUBLIC_APP_URL=https://gem-india.vercel.app
NEXT_PUBLIC_APP_NAME=GEM India
